:root {
  --bg: #0a0a0f;
  --machine-bg: #12121e;
  --panel-bg: #1a1a2e;
  --border: #2a2a4a;
  --neon-blue: #00d4ff;
  --neon-purple: #b44fff;
  --neon-green: #00ff88;
  --neon-pink: #ff2d78;
  --neon-yellow: #ffe600;
  --text: #e0e0ff;
  --text-dim: #6060a0;
  --reel-size: 120px;
  --symbol-size: 100px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Courier New', monospace;
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 20px;
  background-image:
    radial-gradient(ellipse at 20% 50%, rgba(180, 79, 255, 0.08) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 20%, rgba(0, 212, 255, 0.08) 0%, transparent 50%);
}

.machine {
  width: 100%;
  max-width: 600px;
  background: var(--machine-bg);
  border: 2px solid var(--border);
  border-radius: 24px;
  padding: 28px 24px;
  box-shadow:
    0 0 40px rgba(0, 212, 255, 0.12),
    0 0 80px rgba(180, 79, 255, 0.08),
    inset 0 1px 0 rgba(255,255,255,0.05);
}

/* HEADER */
.machine-header {
  text-align: center;
  margin-bottom: 24px;
}

.machine-header h1 {
  font-size: 2.4rem;
  font-weight: 900;
  letter-spacing: 4px;
  color: #fff;
  text-shadow: 0 0 20px rgba(0,212,255,0.4);
}

.neon {
  color: var(--neon-blue);
  text-shadow: 0 0 10px var(--neon-blue), 0 0 30px var(--neon-blue);
  animation: flicker 4s infinite;
}

@keyframes flicker {
  0%, 95%, 100% { opacity: 1; }
  96% { opacity: 0.7; }
  97% { opacity: 1; }
  98% { opacity: 0.5; }
  99% { opacity: 1; }
}

.tagline {
  font-size: 0.78rem;
  color: var(--text-dim);
  letter-spacing: 2px;
  margin-top: 4px;
  text-transform: uppercase;
}

/* BALANCE PANEL */
.balance-panel {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 24px;
}

.balance-item {
  flex: 1;
  background: var(--panel-bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px;
  text-align: center;
}

.balance-item .label {
  display: block;
  font-size: 0.6rem;
  letter-spacing: 2px;
  color: var(--text-dim);
  text-transform: uppercase;
  margin-bottom: 6px;
}

.balance-item .value {
  display: block;
  font-size: 1.5rem;
  font-weight: 900;
  color: var(--neon-yellow);
  text-shadow: 0 0 10px rgba(255, 230, 0, 0.5);
}

.value.won {
  color: var(--neon-green);
  text-shadow: 0 0 10px rgba(0, 255, 136, 0.5);
}

.bet-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.bet-btn {
  background: var(--border);
  border: none;
  color: var(--text);
  width: 26px;
  height: 26px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 1rem;
  font-weight: bold;
  transition: background 0.15s;
}

.bet-btn:hover { background: var(--neon-purple); }

/* REELS */
.reels-wrapper {
  margin-bottom: 16px;
}

.reels-frame {
  position: relative;
  background: #05050d;
  border: 2px solid var(--border);
  border-radius: 16px;
  padding: 16px;
  overflow: hidden;
  box-shadow: inset 0 0 30px rgba(0,0,0,0.8);
}

.reels-frame::before,
.reels-frame::after {
  content: '';
  position: absolute;
  left: 0; right: 0;
  height: 60px;
  z-index: 10;
  pointer-events: none;
}

.reels-frame::before {
  top: 0;
  background: linear-gradient(to bottom, #05050d, transparent);
}

.reels-frame::after {
  bottom: 0;
  background: linear-gradient(to top, #05050d, transparent);
}

.reels {
  display: flex;
  gap: 12px;
  justify-content: center;
}

.reel {
  width: var(--reel-size);
  height: var(--reel-size);
  overflow: hidden;
  border-radius: 8px;
  position: relative;
}

.reel-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.05s linear;
  will-change: transform;
}

.symbol {
  width: var(--reel-size);
  height: var(--reel-size);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3.5rem;
  flex-shrink: 0;
  user-select: none;
}

.payline {
  position: absolute;
  top: 50%;
  left: 0; right: 0;
  height: 4px;
  margin-top: -2px;
  background: linear-gradient(90deg, transparent, var(--neon-yellow), transparent);
  opacity: 0.6;
  z-index: 5;
  pointer-events: none;
}

/* MESSAGE BOX */
.message-box {
  text-align: center;
  padding: 10px 16px;
  border-radius: 10px;
  margin-bottom: 16px;
  font-size: 0.85rem;
  font-weight: bold;
  letter-spacing: 1px;
  background: var(--panel-bg);
  border: 1px solid var(--border);
  min-height: 42px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.message-box.hidden { opacity: 0; }
.message-box.win { border-color: var(--neon-green); color: var(--neon-green); }
.message-box.lose { border-color: var(--neon-pink); color: var(--neon-pink); }
.message-box.info { border-color: var(--neon-blue); color: var(--neon-blue); }

/* CONTROLS */
.controls {
  display: flex;
  gap: 12px;
  margin-bottom: 24px;
  align-items: center;
}

.spin-btn {
  flex: 1;
  background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
  border: none;
  border-radius: 14px;
  color: #fff;
  font-family: 'Courier New', monospace;
  font-weight: 900;
  font-size: 1.2rem;
  letter-spacing: 3px;
  padding: 16px 24px;
  cursor: pointer;
  position: relative;
  transition: transform 0.1s, box-shadow 0.1s, opacity 0.2s;
  box-shadow: 0 0 20px rgba(180, 79, 255, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.spin-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 0 30px rgba(180, 79, 255, 0.7);
}

.spin-btn:active:not(:disabled) { transform: translateY(0); }

.spin-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.spin-cost {
  font-size: 0.65rem;
  opacity: 0.8;
  font-weight: normal;
  letter-spacing: 1px;
}

.secondary-btn {
  background: var(--panel-bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  color: var(--text-dim);
  font-family: 'Courier New', monospace;
  font-size: 0.7rem;
  letter-spacing: 1px;
  padding: 12px 10px;
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s;
  text-transform: uppercase;
}

.secondary-btn:hover {
  border-color: var(--neon-blue);
  color: var(--neon-blue);
}

/* PAYTABLE */
.paytable {
  background: var(--panel-bg);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px;
  margin-bottom: 20px;
}

.paytable h3 {
  font-size: 0.75rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--neon-purple);
  margin-bottom: 12px;
  text-align: center;
}

.paytable .small {
  font-size: 0.6rem;
  color: var(--text-dim);
  letter-spacing: 1px;
}

.pay-rows {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
}

.pay-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  padding: 4px 8px;
  border-radius: 6px;
  background: rgba(255,255,255,0.03);
}

.pay-symbols { font-size: 1.1rem; letter-spacing: -2px; }
.pay-multiplier { color: var(--neon-yellow); font-weight: bold; margin-left: auto; white-space: nowrap; }

/* WIN OVERLAY */
.win-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  cursor: pointer;
  animation: fadeIn 0.3s ease;
}

.win-overlay.hidden { display: none; }

.win-content {
  text-align: center;
  animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.win-emoji {
  font-size: 5rem;
  margin-bottom: 16px;
  animation: spin3d 0.6s ease;
}

.win-title {
  font-size: 2rem;
  font-weight: 900;
  letter-spacing: 4px;
  color: var(--neon-yellow);
  text-shadow: 0 0 20px var(--neon-yellow);
  margin-bottom: 8px;
}

.win-subtitle {
  font-size: 0.9rem;
  color: var(--text-dim);
  max-width: 320px;
  margin: 0 auto 16px;
  line-height: 1.5;
}

.win-amount {
  font-size: 1.5rem;
  color: var(--neon-green);
  font-weight: 900;
  text-shadow: 0 0 15px var(--neon-green);
}

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes popIn {
  from { transform: scale(0.5); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
@keyframes spin3d {
  from { transform: rotateY(180deg) scale(0.5); }
  to { transform: rotateY(0) scale(1); }
}

/* REEL SPINNING ANIMATION */
.reel.spinning .reel-inner {
  transition: none;
}

/* WINNER HIGHLIGHT */
.reel.winner {
  box-shadow: 0 0 20px var(--neon-yellow), inset 0 0 10px rgba(255,230,0,0.2);
  border: 2px solid var(--neon-yellow);
}

/* FOOTER */
.machine-footer {
  text-align: center;
  font-size: 0.65rem;
  color: var(--text-dim);
  line-height: 1.8;
}

.machine-footer .asterisk { font-size: 0.58rem; opacity: 0.6; }

/* SHAKE ANIMATION */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-8px); }
  40% { transform: translateX(8px); }
  60% { transform: translateX(-5px); }
  80% { transform: translateX(5px); }
}

.shake { animation: shake 0.4s ease; }

/* BALANCE FLASH */
@keyframes flashGreen {
  0%, 100% { color: var(--neon-yellow); text-shadow: 0 0 10px rgba(255,230,0,0.5); }
  50% { color: var(--neon-green); text-shadow: 0 0 20px var(--neon-green); }
}
@keyframes flashRed {
  0%, 100% { color: var(--neon-yellow); text-shadow: 0 0 10px rgba(255,230,0,0.5); }
  50% { color: var(--neon-pink); text-shadow: 0 0 20px var(--neon-pink); }
}
.flash-green { animation: flashGreen 0.5s ease; }
.flash-red { animation: flashRed 0.5s ease; }

@media (max-width: 480px) {
  :root { --reel-size: 90px; }
  .machine-header h1 { font-size: 1.8rem; }
  .pay-rows { grid-template-columns: 1fr; }
  .controls { flex-wrap: wrap; }
}
